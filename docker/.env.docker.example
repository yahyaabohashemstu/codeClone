# =============================================================================
# Clone Lens -- Docker environment variables
#
# Copy this file to .env in the docker/ directory and fill in real values
# before running `docker compose ... up`.
#
#   cp .env.docker.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
# REQUIRED in production -- used for session signing and CSRF protection.
SECRET_KEY=replace-me-with-a-long-random-string

# Flask environment: "development" or "production"
FLASK_ENV=production

# Waitress thread pool size (default: 8)
WAITRESS_THREADS=8

# ---------------------------------------------------------------------------
# PostgreSQL  (production only)
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=codeclone_secret

# The backend reads DATABASE_URL; it is constructed automatically in
# docker-compose.prod.yml from POSTGRES_PASSWORD.  Override here only
# if you use an external database.
# DATABASE_URL=postgresql://codeclone:codeclone_secret@postgres:5432/codeclone

# ---------------------------------------------------------------------------
# Redis  (production only)
# ---------------------------------------------------------------------------
# Override only if you use an external Redis instance.
# REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# AI / Mistral
# ---------------------------------------------------------------------------
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# ---------------------------------------------------------------------------
# Enterprise features
# ---------------------------------------------------------------------------
ENTERPRISE_DATA_KEY=
