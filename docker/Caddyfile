# Caddy reverse proxy with automatic HTTPS (Let's Encrypt).
#
# SITE_ADDRESS is your domain, e.g. codesimilar.com — Caddy obtains and renews
# the TLS certificate automatically once the domain's DNS points at this host.
# For a local test without a public domain use SITE_ADDRESS=localhost (Caddy
# issues a local self-signed cert).

{$SITE_ADDRESS} {
	encode gzip zstd
	# The app container serves both the SPA and the API on port 5000.
	reverse_proxy app:5000

	# Reasonable upload ceiling (matches the backend MAX_CONTENT_LENGTH).
	request_body {
		max_size 110MB
	}
}
