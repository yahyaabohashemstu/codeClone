      "items": [
        {
          "question": "\u0645\u0627 \u0644\u063a\u0627\u062a \u0627\u0644\u0628\u0631\u0645\u062c\u0629 \u0627\u0644\u0645\u062f\u0639\u0648\u0645\u0629\u061f",
          "answer": "\u064a\u062f\u0639\u0645 Clone Lens \u0644\u063a\u0627\u062a Java \u0648JavaScript \u0648TypeScript \u0648Python \u0648C/C++ \u0648C# \u0648Go \u0648Ruby \u0648PHP \u0648Swift \u0648Kotlin. \u0643\u0645\u0627 \u064a\u0633\u062a\u0637\u064a\u0639 \u0627\u0644\u062a\u062d\u0644\u064a\u0644 \u0627\u0644\u062f\u0644\u0627\u0644\u064a \u0648\u0627\u0644\u0645\u062f\u0639\u0648\u0645 \u0628\u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0627\u0643\u062a\u0634\u0627\u0641 \u0627\u0644\u0623\u0646\u0645\u0627\u0637 \u0639\u0628\u0631 \u0644\u063a\u0627\u062a \u0645\u062e\u062a\u0644\u0641\u0629."
        },
        {
          "question": "\u0643\u064a\u0641 \u064a\u0639\u0645\u0644 \u0643\u0634\u0641 \u0627\u0644\u0646\u0633\u062e\u061f",
          "answer": "\u064a\u0639\u062a\u0645\u062f \u0627\u0644\u0646\u0638\u0627\u0645 \u0639\u0644\u0649 \u0623\u0631\u0628\u0639 \u0637\u0628\u0642\u0627\u062a: \u062a\u062d\u0644\u064a\u0644 \u0627\u0644\u062a\u0648\u0643\u0646\u0627\u062a \u0644\u0644\u0646\u0633\u062e \u0645\u0646 \u0627\u0644\u0646\u0648\u0639\u064a\u0646 1 \u06482\u060c \u0648\u062a\u0634\u0627\u0628\u0647 \u0627\u0644\u0646\u0635 \u0644\u0644\u0646\u0633\u062e \u0627\u0644\u0642\u0631\u064a\u0628\u0629\u060c \u0648\u0645\u0642\u0627\u0631\u0646\u0629 \u0631\u0633\u0645 AST \u0644\u0644\u0623\u0646\u0645\u0627\u0637 \u0627\u0644\u0628\u0646\u064a\u0648\u064a\u0629\u060c \u0648\u0627\u0644\u062a\u062d\u0644\u064a\u0644 \u0627\u0644\u062f\u0644\u0627\u0644\u064a \u0628\u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0644\u0644\u0634\u064a\u0641\u0631\u0627\u062a \u0627\u0644\u0645\u062a\u0643\u0627\u0641\u0626\u0629 \u0648\u0638\u064a\u0641\u064a\u064b\u0627 \u0631\u063a\u0645 \u0627\u062e\u062a\u0644\u0627\u0641\u0647\u0627 \u0646\u062d\u0648\u064a\u064b\u0627."
        },
        {
          "question": "\u0645\u0627 \u0623\u0646\u0648\u0627\u0639 \u0627\u0644\u0645\u0644\u0641\u0627\u062a \u0627\u0644\u062a\u064a \u064a\u0645\u0643\u0646\u0646\u064a \u0631\u0641\u0639\u0647\u0627\u061f",
          "answer": "\u0645\u0644\u0641\u0627\u062a \u0628\u0631\u0645\u062c\u064a\u0629 \u0641\u0631\u062f\u064a\u0629 (.java \u0648.js \u0648.ts \u0648.py \u0648\u063a\u064a\u0631\u0647\u0627)\u060c \u0623\u0648 \u0623\u0631\u0634\u064a\u0641\u0627\u062a ZIP \u0644\u0645\u0634\u0627\u0631\u064a\u0639 \u0643\u0627\u0645\u0644\u0629\u060c \u0623\u0648 \u0645\u0644\u0641\u0627\u062a Excel/CSV \u062a\u062d\u062a\u0648\u064a \u0639\u0644\u0649 \u0645\u0642\u0627\u0637\u0639 \u0628\u0631\u0645\u062c\u064a\u0629 \u0645\u0639 \u0625\u0645\u0643\u0627\u0646\u064a\u0629 \u0627\u062e\u062a\u064a\u0627\u0631 \u0627\u0644\u0635\u0641."
        },
        {
          "question": "\u0643\u064a\u0641 \u062a\u064f\u062d\u0633\u0628 \u0646\u0633\u0628\u0629 \u0627\u0644\u062a\u0634\u0627\u0628\u0647\u061f",
          "answer": "\u0627\u0644\u0646\u0633\u0628\u0629 \u0627\u0644\u0643\u0644\u064a\u0629 \u0647\u064a \u0645\u062a\u0648\u0633\u0637 \u0645\u0648\u0632\u0648\u0646 \u0644\u0646\u062a\u0627\u0626\u062c \u0627\u0644\u062a\u0648\u0643\u0646\u0627\u062a \u0648\u0627\u0644\u0646\u0635 \u0648\u0631\u0633\u0645 AST \u0648\u0627\u0644\u062a\u0634\u0627\u0628\u0647 \u0627\u0644\u0645\u062f\u0639\u0648\u0645 \u0628\u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a. \u064a\u062a\u0645 \u062a\u062d\u062f\u064a\u062f \u0627\u0644\u0623\u0648\u0632\u0627\u0646 \u062f\u064a\u0646\u0627\u0645\u064a\u0643\u064a\u064b\u0627 \u0648\u0641\u0642 \u062e\u0635\u0627\u0626\u0635 \u0627\u0644\u0634\u064a\u0641\u0631\u0629 \u0644\u062a\u062d\u0642\u064a\u0642 \u0623\u0639\u0644\u0649 \u062f\u0642\u0629 \u0645\u0645\u0643\u0646\u0629."
        },
        {
          "question": "\u0647\u0644 \u064a\u0645\u0643\u0646\u0646\u064a \u062f\u0645\u062c \u0627\u0644\u0646\u0638\u0627\u0645 \u0645\u0639 \u0645\u0633\u0627\u0631 CI/CD\u061f",
          "answer": "\u0646\u0639\u0645. \u064a\u0648\u0641\u0651\u0631 Clone Lens \u0648\u0627\u062c\u0647\u0627\u062a API \u064a\u0645\u0643\u0646\u0643 \u0627\u0633\u062a\u062f\u0639\u0627\u0624\u0647\u0627 \u0645\u0646 \u0623\u064a \u0646\u0638\u0627\u0645 CI/CD. \u0648\u064a\u0645\u0643\u0646\u0643 \u0636\u0628\u0637 \u062d\u062f\u0648\u062f \u0644\u0644\u062a\u0634\u0627\u0628\u0647 \u062a\u0624\u062f\u064a \u0625\u0644\u0649 \u0641\u0634\u0644 \u0627\u0644\u0628\u0646\u0627\u0621 \u0639\u0646\u062f \u062a\u062c\u0627\u0648\u0632 \u0627\u0644\u062a\u0643\u0631\u0627\u0631 \u0627\u0644\u0645\u0633\u062a\u0648\u0649 \u0627\u0644\u0645\u0642\u0628\u0648\u0644."
        },
        {
          "question": "\u0647\u0644 \u0634\u064a\u0641\u0631\u062a\u064a \u0622\u0645\u0646\u0629 \u0639\u0646\u062f \u0631\u0641\u0639\u0647\u0627\u061f",
          "answer": "\u062a\u064f\u0634\u0641\u064e\u0651\u0631 \u0627\u0644\u0634\u064a\u0641\u0631\u0629 \u0623\u062b\u0646\u0627\u0621 \u0627\u0644\u0646\u0642\u0644 \u0648\u0627\u0644\u062a\u062e\u0632\u064a\u0646\u060c \u0648\u0644\u0627 \u0646\u0634\u0627\u0631\u0643\u0647\u0627 \u0645\u0639 \u0623\u064a \u0637\u0631\u0641 \u062b\u0627\u0644\u062b. \u0648\u064a\u0645\u0643\u0646 \u0644\u0639\u0645\u0644\u0627\u0621 \u0627\u0644\u0645\u0624\u0633\u0633\u0627\u062a \u0637\u0644\u0628 \u0646\u0634\u0631 \u062f\u0627\u062e\u0644\u064a \u0643\u0627\u0645\u0644 \u0644\u0644\u062d\u0641\u0627\u0638 \u0639\u0644\u0649 \u0633\u064a\u0627\u062f\u0629 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a."
        }
      ]
    },
