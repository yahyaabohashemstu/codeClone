# ============================================================
# CodeClone Platform — Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# --- Flask Core ---
# SECRET_KEY=                # Session signing key. Auto-generated if unset (stored in instance/secret_key).
#                            # REQUIRED in production (FLASK_ENV=production) -- the app refuses to start without it.
# FLASK_ENV=production       # 'development' (default), 'production', or 'testing'. Production enables secure cookies.
# SESSION_COOKIE_SECURE=1    # Secure cookies are the production default. Set to 0 ONLY for a
#                            # plain-HTTP deployment (e.g. the docker stack before TLS) — otherwise
#                            # browsers drop the session cookie and login never persists.
# DATABASE_URL=              # SQLAlchemy URL. Defaults to sqlite:///instance/clonedetector.db.
#                            # Postgres (postgresql://...) requires psycopg2 (in requirements.txt).

# --- Server Binding ---
# BIND_HOST=127.0.0.1        # Default binds to localhost only. MUST be 0.0.0.0 inside Docker
#                            # (the compose files set this) or the container is unreachable.
# PORT=5000                  # HTTP port
# WAITRESS_THREADS=8         # Worker threads for Waitress WSGI server

# --- AI / LLM ---
# MISTRAL_API_KEY=           # Mistral API key (or store in instance/mistral_api_key)
# MISTRAL_MODEL=mistral-small-latest

# --- Admin Bootstrap ---
# DEFAULT_ADMIN_USERNAME=admin
# DEFAULT_ADMIN_PASSWORD=    # Min 8 chars; set on first run when no users exist.
#                            # If unset, a random password is generated and written to
#                            # instance/bootstrap_admin_credentials.txt.

# --- Enterprise Platform ---
# ENTERPRISE_DATA_KEY=       # Encryption key for enterprise data at rest (REQUIRED for enterprise features).
#                            # If unset, the app falls back to SECRET_KEY -- rotating SECRET_KEY would then
#                            # make existing encrypted enterprise data unrecoverable, so set this explicitly.
# ENTERPRISE_USE_WORKER=     # Set to 1 to leave scan jobs queued for the standalone
#                            # enterprise_worker.py process (docker prod stack does this);
#                            # unset/0 runs scans in-process on a thread pool.
# ENTERPRISE_SCAN_RECLAIM_SECONDS=1800
#                            # In-process mode: requeue scans stuck in 'running' (crashed process)
#                            # after this many seconds. Must exceed your longest legitimate scan.
# ENTERPRISE_LOCAL_REPOSITORY_ROOTS=
#                            # os.pathsep-separated allowlist of directories from which
#                            # provider=local repositories may be registered/scanned.

# --- Background Analysis & Scaling ---
# BG_ANALYSIS_WORKERS=2      # Thread-pool size for async code analyses.
# STALE_TASK_MINUTES=30      # How long a finished background task is retained before cleanup.
# STALE_PROGRESS_MINUTES=5   # How long stale progress entries are retained.
# REDIS_URL=                 # Rate-limit storage (e.g. redis://...). Defaults to in-process memory://.

# --- CI/CD Integration ---
# CI_API_KEY=                # Shared secret for POST /api/v1/ci/check (simple, non-enterprise tokens).

# --- Frontend (Vite) ---
# VITE_API_BASE_URL=         # Leave EMPTY. The app is same-origin only (no CORS on the backend,
#                            # CSP connect-src 'self', SameSite cookies). Serve the SPA from the
#                            # backend (start.bat) or behind the Nginx /api proxy (docker).
