# ============================================================
# Clone Lens Platform — Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# --- Flask Core ---
# SECRET_KEY=                # Session signing key. Auto-generated if unset (stored in instance/secret_key).
#                            # REQUIRED in production (FLASK_ENV=production) -- the app refuses to start without it.
# FLASK_ENV=production       # 'development' (default), 'production', or 'testing'. Production enables secure cookies.
# SESSION_COOKIE_SECURE=1    # Secure cookies are the production default. Set to 0 ONLY for a
#                            # plain-HTTP deployment (e.g. the docker stack before TLS) — otherwise
#                            # browsers drop the session cookie and login never persists.
# TRUST_PROXY_HEADERS=0      # Number of trusted reverse-proxy hops. Set to 1 behind a single
#                            # TLS-terminating proxy (Caddy/Nginx/Coolify) so X-Forwarded-Proto
#                            # (https scheme) and X-Forwarded-For (per-client rate limiting) work.
#                            # Leave 0 when NOT behind a proxy (prevents client-IP spoofing).
# DATABASE_URL=              # SQLAlchemy URL. Defaults to sqlite:///instance/clonedetector.db.
#                            # Postgres (postgresql://...) requires psycopg2 (in requirements.txt).

# --- Server Binding ---
# BIND_HOST=127.0.0.1        # Default binds to localhost only. MUST be 0.0.0.0 inside Docker
#                            # (the compose files set this) or the container is unreachable.
# PORT=5000                  # HTTP port
# WAITRESS_THREADS=8         # Worker threads for Waitress WSGI server

# --- AI / LLM ---
# MISTRAL_API_KEY=           # Mistral API key (or store in instance/mistral_api_key)
# MISTRAL_MODEL=mistral-small-latest

# --- Admin Bootstrap ---
# DEFAULT_ADMIN_USERNAME=admin
# DEFAULT_ADMIN_PASSWORD=    # Min 8 chars; set on first run when no users exist.
#                            # If unset, a random password is generated and written to
#                            # instance/bootstrap_admin_credentials.txt.

# --- Enterprise Platform ---
# ENTERPRISE_DATA_KEY=       # Encryption key for enterprise data at rest (REQUIRED for enterprise features).
#                            # If unset, the app falls back to SECRET_KEY -- rotating SECRET_KEY would then
#                            # make existing encrypted enterprise data unrecoverable, so set this explicitly.
# ENTERPRISE_USE_WORKER=     # Set to 1 to leave scan jobs queued for the standalone
#                            # enterprise_worker.py process (docker prod stack does this);
#                            # unset/0 runs scans in-process on a thread pool.
# ENTERPRISE_SCAN_RECLAIM_SECONDS=1800
#                            # In-process mode: requeue scans stuck in 'running' (crashed process)
#                            # after this many seconds. Must exceed your longest legitimate scan.
# ENTERPRISE_LOCAL_REPOSITORY_ROOTS=
#                            # os.pathsep-separated allowlist of directories from which
#                            # provider=local repositories may be registered/scanned.
# ENTERPRISE_ALLOWED_GIT_HOSTS=
#                            # SSRF control for server-side git clone/probe. Unset => a safe default
#                            # allowlist (github.com, gitlab.com, bitbucket.org). Comma-separate to add
#                            # hosts (e.g. self-hosted GitLab), or set to "*" to allow any PUBLIC host
#                            # (private/loopback/metadata IPs are always rejected).
# ENTERPRISE_MAX_ACTIVE_SCANS_PER_REPO=5
#                            # Cap on queued/claimed/running scans per repository. Bounds the clone
#                            # workqueue so a reviewer (or leaked write-scoped key) cannot enqueue
#                            # unbounded git clones. Triggers beyond the cap get HTTP 429.
# ENTERPRISE_MAX_CACHED_WORKSPACE_INDEXES=16
#                            # LRU cap on how many workspaces' in-memory embedding indexes are held
#                            # resident at once. Bounds multi-tenant RAM; evicted indexes rebuild on
#                            # next access. Raise on big-RAM single-tenant hosts.

# --- Background Analysis & Scaling ---
# BG_ANALYSIS_WORKERS=2      # Thread-pool size for async code analyses.
# MAX_CACHE_BYTES=536870912  # Aggregate byte budget (default 512 MB) for the per-user analysis-context
#                            # cache. Bounds total RAM even when cached results hold large ZIP-derived
#                            # sources; LRU entries are evicted until the total fits.
# STALE_TASK_MINUTES=30      # How long a finished background task is retained before cleanup.
# STALE_PROGRESS_MINUTES=5   # How long stale progress entries are retained.
# REDIS_URL=                 # Rate-limit storage (e.g. redis://...). Defaults to in-process memory://.
# COORDINATION_BACKEND=       # Auto: defaults to 'redis' when REDIS_URL is set (state shared across
#                            # replicas so load-balanced polling works), else 'memory' (single replica).
#                            # Set explicitly to override; degrades to in-process if Redis is unreachable.

# --- CI/CD Integration ---
# CI_API_KEY=                # Shared secret for POST /api/v1/ci/check (simple, non-enterprise tokens).

# --- Accounts / Self-service auth ---
# APP_BASE_URL=              # Public base URL (e.g. https://app.example.com) used to build
#                            # verification / password-reset links in emails. Relative links if unset.
# ALLOW_SELF_REGISTRATION=1  # 1 (default) exposes POST /api/v1/auth/signup; set 0 to disable public signup.
# REQUIRE_EMAIL_VERIFICATION=0
#                            # 1 blocks login for unverified email accounts (admins exempt).
#                            # Keep 0 unless SMTP is configured, or users cannot get verification mail.
# EMAIL_VERIFICATION_MAX_AGE=259200   # Verification link lifetime (seconds, default 3 days).
# PASSWORD_RESET_MAX_AGE=3600         # Reset link lifetime (seconds, default 1 hour).
# LOGIN_MAX_ATTEMPTS=8                # Failed logins before an account is temporarily locked.
# LOGIN_LOCKOUT_MINUTES=15            # How long an account stays locked after too many failures.
# PASSWORD_BREACH_CHECK=0             # 1 enables a best-effort Have I Been Pwned k-anonymity check
#                                     # on password set/reset (outbound API call; never blocks login).

# --- Email Delivery ---
# EMAIL_PROVIDER=console     # 'console' (default; logs the message), 'smtp', or 'disabled'.
# EMAIL_FROM=no-reply@clonelens.com
# SMTP_HOST=                 # Required when EMAIL_PROVIDER=smtp.
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_USE_TLS=1

# --- Billing (Stripe, optional) ---
# When STRIPE_SECRET_KEY is unset, billing endpoints return 503 and everyone
# stays on the free plan (monthly analysis quotas still apply).
# STRIPE_SECRET_KEY=         # sk_live_... / sk_test_...
# STRIPE_WEBHOOK_SECRET=     # whsec_... (verify POST /api/v1/billing/webhook)
# STRIPE_PRICE_PRO=          # Stripe price id for the Pro plan
# STRIPE_PRICE_TEAM=         # Stripe price id for the Team plan
# BILLING_SUCCESS_URL=       # Post-checkout redirect (defaults to {APP_BASE_URL}/billing?status=success)
# BILLING_CANCEL_URL=

# --- Observability ---
# LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
# SENTRY_DSN=                # Enables Sentry error tracking when set (requires 'sentry-sdk').
# SENTRY_TRACES_SAMPLE_RATE=0
# METRICS_ENABLED=0          # 1 exposes Prometheus metrics at /api/v1/metrics (requires
#                            # 'prometheus-client'). Bind internally or protect with METRICS_TOKEN.
# METRICS_TOKEN=             # Optional bearer token required to scrape /api/v1/metrics.
# METRICS_ALLOW_UNAUTHENTICATED=0    # If METRICS_ENABLED=1 but no METRICS_TOKEN is set, the endpoint
#                                    # refuses to serve (fail-safe). Set 1 to intentionally serve openly.

# --- Frontend (Vite) ---
# VITE_API_BASE_URL=         # Leave EMPTY. The app is same-origin only (no CORS on the backend,
#                            # CSP connect-src 'self', SameSite cookies). Serve the SPA from the
#                            # backend (start.bat) or behind the Nginx /api proxy (docker).
