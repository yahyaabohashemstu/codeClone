# ============================================================
# CodeClone Platform — Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# --- Flask Core ---
# FLASK_SECRET_KEY=          # Auto-generated if not set (stored in instance/secret_key)
# FLASK_ENV=production       # Set to 'production' for secure cookies

# --- Server Binding ---
# BIND_HOST=127.0.0.1        # Use 0.0.0.0 to expose to network
# PORT=5000                  # HTTP port
# WAITRESS_THREADS=8         # Worker threads for Waitress WSGI server

# --- AI / LLM ---
# MISTRAL_API_KEY=           # Mistral API key (or store in instance/mistral_api_key)
# MISTRAL_MODEL=mistral-small-latest

# --- Admin Bootstrap ---
# DEFAULT_ADMIN_USERNAME=admin
# DEFAULT_ADMIN_PASSWORD=    # Min 12 chars, set on first run when no users exist

# --- Enterprise Platform ---
# ENTERPRISE_DATA_KEY=       # Encryption key for enterprise data (REQUIRED for enterprise features)

# --- Frontend (Vite) ---
# VITE_API_BASE_URL=         # API base URL for production (empty = same-origin proxy)
